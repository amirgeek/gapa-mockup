VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key
MERCADOPAGO_ACCESS_TOKEN=your-mercadopago-access-token
# Optional if later you embed frontend components from Mercado Pago.
MERCADOPAGO_PUBLIC_KEY=your-mercadopago-public-key
# Service role key (Supabase Settings > API). Backend-only: lets the
# create-preference and mercadopago-webhook functions write membership
# status and payment records bypassing RLS. Never expose with a VITE_ prefix.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
